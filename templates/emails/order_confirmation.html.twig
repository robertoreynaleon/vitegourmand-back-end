{% extends 'emails/layout.html.twig' %}

{% block subject %}Confirmation de votre commande #{{ order.id }}{% endblock %}

{% block content %}
    <h2>Commande confirmée ✓</h2>

    <p>Bonjour {{ user.name }},</p>

    <p>Nous avons bien reçu votre commande <strong>#{{ order.id }}</strong>. Notre équipe se met au travail !</p>

    <div class="highlight-box">
        <p><strong>Récapitulatif</strong><br>
        Commande n° {{ order.id }}<br>
        Date : {{ order.orderDate ? order.orderDate|date('d/m/Y à H:i') : 'N/A' }}<br>
        Livraison : {{ order.deliveryDate ? order.deliveryDate|date('d/m/Y') : 'N/A' }} à {{ order.deliveryTime ? order.deliveryTime|date('H:i') : 'N/A' }}<br>
        Adresse : {{ order.deliveryAddress }}<br>
        Montant total : {{ order.totalAmount|number_format(2, ',', ' ') }} €<br>
        Statut : {{ order.status.value }}</p>
    </div>

    <p>
        <a href="http://localhost:3000/user/orders" class="btn">Suivre ma commande</a>
    </p>

    <p>Merci pour votre confiance,<br><strong>L'équipe Vite &amp; Gourmand</strong></p>
{% endblock %}
