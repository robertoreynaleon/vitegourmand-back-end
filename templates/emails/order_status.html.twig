{% extends 'emails/layout.html.twig' %}

{% block subject %}Mise à jour de votre commande #{{ order.id }}{% endblock %}

{% block content %}
    <h2>Votre commande a été mise à jour</h2>

    <p>Bonjour {{ user.name }},</p>

    <p>Le statut de votre commande <strong>#{{ order.id }}</strong> vient d'être mis à jour.</p>

    <div class="highlight-box">
        <p><strong>Nouveau statut :</strong> {{ order.status is defined ? order.status : 'Mis à jour' }}</p>
    </div>

    <p>
        <a href="http://localhost:3000/mes-commandes" class="btn">Voir ma commande</a>
    </p>

    <p>Cordialement,<br><strong>L'équipe Vite &amp; Gourmand</strong></p>
{% endblock %}
