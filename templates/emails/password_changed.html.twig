{% extends 'emails/layout.html.twig' %}

{% block subject %}Votre mot de passe a été modifié{% endblock %}

{% block content %}
    <h2>Modification de mot de passe</h2>

    <p>Bonjour {{ user.name }},</p>

    <p>Votre mot de passe a été modifié avec succès sur votre compte <strong>{{ user.email }}</strong>.</p>

    <div class="highlight-box">
        <p>⚠️ Si vous n'êtes pas à l'origine de cette modification, contactez-nous immédiatement.</p>
    </div>

    <p>
        <a href="https://vitegourmand-frontend.vercel.app/auth/login/" class="btn">Accéder à mon compte</a>
    </p>

    <p>Cordialement,<br><strong>L'équipe Vite &amp; Gourmand</strong></p>
{% endblock %}
